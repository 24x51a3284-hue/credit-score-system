# ─── Copy this file to .env and fill in your values ──────────────────────────

# JWT — generate a long random string:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_YOUR_SECRET_KEY_64_CHARS_LONG

# Database — get this from Neon.tech or Supabase dashboard
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/creditdb?sslmode=require

# CORS — add your Vercel URL after deploy
ALLOWED_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]

# Paths to ML model files (relative to backend directory)
MODEL_PATH=models/credit_model.pkl
SCALER_PATH=models/scaler.pkl
FEATURE_NAMES_PATH=models/feature_names.pkl

# Debug mode (set to False in production)
DEBUG=False
